/* components/navbar/index.wxss */

/* 导航栏容器 */
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
}

/* 导航栏内容 */
.navbar__content {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;      /* 44px */
  padding: 0 32rpx;   /* 16px */
  position: relative;
}

/* 左侧区域 */
.navbar__left {
  position: absolute;
  left: 32rpx;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  z-index: 2;
}

/* 返回按钮 */
.navbar__back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  margin-left: -16rpx;
}

.navbar__back-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 标题 */
.navbar__title {
  font-size: 34rpx;    /* 17px */
  font-weight: 600;
  text-align: center;
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.25;
}

/* 右侧区域 */
.navbar__right {
  position: absolute;
  right: 32rpx;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  z-index: 2;
}

.navbar__right-text {
  font-size: 28rpx;    /* 14px */
  font-weight: 500;
}

/* ============================================
   导航栏类型样式（按设计系统）
   ============================================ */

/* 紫色底 - 纯色 #534AB7 */
.navbar--purple {
  background: #534ab7;
}

.navbar--purple .navbar__title {
  color: #ffffff;
}

.navbar--purple .navbar__right-text {
  color: #ffffff;
}

/* 白色底 */
.navbar--white {
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

.navbar--white .navbar__title {
  color: #1a1a1a;
}

.navbar--white .navbar__right-text {
  color: #534ab7;
}

/* 透明沉浸式 */
.navbar--transparent {
  background: transparent;
}

.navbar--transparent .navbar__title {
  color: #1a1a1a;
}

.navbar--transparent .navbar__right-text {
  color: #534ab7;
}

/* 占位元素 */
.navbar__placeholder {
  width: 100%;
}
