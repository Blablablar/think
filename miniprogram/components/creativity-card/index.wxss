/* components/creativity-card/index.wxss */

/* 卡片容器 - 按设计系统 .card + .card__body */
.card {
  background: #ffffff;
  border-radius: 24rpx;       /* radius-lg 12px */
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.04), 0 2rpx 4rpx rgba(0, 0, 0, 0.06);
  padding: 32rpx;             /* space-4 16px */
  margin-bottom: 24rpx;       /* space-3 12px */
  overflow: hidden;
}

/* ============================================
   推荐理由 - .discover-card__reason
   ============================================ */
.reason {
  display: inline-flex;
  align-items: center;
  height: 44rpx;              /* 22px */
  padding: 0 16rpx;           /* space-2 8px */
  border-radius: 22rpx;
  font-size: 22rpx;           /* text-2xs 11px */
  color: #534ab7;
  background: #f5f3ff;        /* brand-purple-50 */
  font-weight: 500;
  margin-bottom: 16rpx;       /* space-2 8px */
}

/* ============================================
   作者信息 - .discover-card__meta
   ============================================ */
.meta {
  display: flex;
  align-items: center;
  gap: 16rpx;                 /* space-2 8px */
  margin-bottom: 16rpx;       /* space-2 8px */
}

.meta__avatar {
  width: 64rpx;               /* avatar--sm 32px */
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #eae6ff;
}

.meta__avatar--default {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.meta__name {
  font-size: 28rpx;           /* text-md 14px */
  font-weight: 500;
  color: #1a1a1a;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta__time {
  font-size: 24rpx;           /* text-sm 12px */
  color: #999999;
  flex-shrink: 0;
}

/* ============================================
   标题 - .discover-card__title
   ============================================ */
.title {
  font-size: 30rpx;           /* text-base 15px */
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.25;
  margin-bottom: 16rpx;       /* space-2 8px */
}

/* ============================================
   摘要 - .discover-card__desc
   ============================================ */
.desc {
  font-size: 28rpx;           /* text-md 14px */
  color: #666666;
  line-height: 1.6;           /* leading-relaxed */
  margin-bottom: 24rpx;       /* space-3 12px */
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ============================================
   图片展示 - .discover-card__images
   ============================================ */
.images {
  margin-bottom: 24rpx;       /* space-3 12px */
}

/* 单图：全宽 160px 高 */
.images__single {
  width: 100%;
  height: 320rpx;             /* 160px */
  border-radius: 16rpx;       /* radius-md 8px */
  background: #f7f8fa;
  display: block;
}

/* 多图：横滑 */
.images__scroll {
  width: 100%;
  white-space: nowrap;
}

.images__multi {
  display: inline-flex;
  gap: 12rpx;                 /* 6px */
}

.images__item {
  width: 208rpx;              /* 104px */
  height: 208rpx;
  border-radius: 16rpx;       /* radius-md 8px */
  background: #f7f8fa;
  flex-shrink: 0;
}

/* ============================================
   底部互动栏 - .discover-card__stats
   ============================================ */
.stats {
  display: flex;
  align-items: center;
  gap: 32rpx;                 /* space-4 16px */
  font-size: 24rpx;           /* text-sm 12px */
  color: #999999;
  padding-top: 24rpx;         /* space-3 12px */
  border-top: 1rpx solid #f0f0f0;  /* border-divider 0.5px */
}

.stats__item {
  display: flex;
  align-items: center;
  gap: 6rpx;                  /* 3px */
}

.stats__item--right {
  flex: 1;
  justify-content: flex-end;
}

.stats__icon {
  width: 28rpx;               /* 14px */
  height: 28rpx;
}

.stats__text {
  font-size: 24rpx;           /* text-sm 12px */
  color: #999999;
}

.stats__text--active {
  color: #fa9d3b;             /* color-warning */
}
