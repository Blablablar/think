<!-- components/creativity-card/index.wxml -->
<view class="card" bindtap="onCardClick">
  <!-- 推荐理由标签 -->
  <view wx:if="{{data.recommendReason}}" class="reason">
    <text>{{data.recommendReason}}</text>
  </view>

  <!-- 作者信息 -->
  <view class="meta">
    <image wx:if="{{data.author.avatar}}" class="meta__avatar" src="{{data.author.avatar}}" mode="aspectFill"></image>
    <view wx:else class="meta__avatar meta__avatar--default">👤</view>
    <text class="meta__name">{{data.author.name || '微信用户'}}</text>
    <text class="meta__time">{{data.createdAt}}</text>
  </view>

  <!-- 标题 -->
  <view wx:if="{{data.title}}" class="title">{{data.title}}</view>

  <!-- 摘要 -->
  <view wx:if="{{data.summary}}" class="desc">{{data.summary}}</view>

  <!-- 图片展示 -->
  <view wx:if="{{data.images.length > 0}}" class="images">
    <!-- 单图：全宽 -->
    <image
      wx:if="{{data.images.length === 1}}"
      class="images__single"
      src="{{data.images[0]}}"
      mode="aspectFill"
      lazy-load
      catchtap="onPreviewImage"
      data-index="0"
    ></image>

    <!-- 多图：横滑 -->
    <scroll-view wx:else scroll-x class="images__scroll">
      <view class="images__multi">
        <image
          wx:for="{{data.images}}"
          wx:key="*this"
          class="images__item"
          src="{{item}}"
          mode="aspectFill"
          lazy-load
          catchtap="onPreviewImage"
          data-index="{{index}}"
        ></image>
      </view>
    </scroll-view>
  </view>

  <!-- 底部互动栏 -->
  <view class="stats">
    <view class="stats__item" catchtap="onLike">
      <image class="stats__icon" src="{{data.isLiked ? icons.heartActive : icons.heart}}"></image>
      <text class="stats__text">{{data.stats.likes || 0}}</text>
    </view>
    <view class="stats__item" catchtap="onComment">
      <image class="stats__icon" src="{{icons.comment}}"></image>
      <text class="stats__text">{{data.stats.comments || 0}}</text>
    </view>
    <view class="stats__item stats__item--right" catchtap="onFavorite">
      <image class="stats__icon" src="{{data.isFavorited ? icons.starActive : icons.star}}"></image>
      <text class="stats__text {{data.isFavorited ? 'stats__text--active' : ''}}">{{data.stats.favorites || 0}}</text>
    </view>
  </view>
</view>
