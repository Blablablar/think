/* pages/recommend/index.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #4ecdc4 0%, #f8f9fe 40%);
  background-attachment: fixed;
}

.header {
  padding: 32rpx 32rpx 48rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.header-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

.content {
  padding: 0 32rpx 180rpx;
  height: calc(100vh - 220rpx);
  box-sizing: border-box;
}

.content::after {
  content: '';
  display: block;
  height: env(safe-area-inset-bottom);
}

.card-container {
  position: relative;
  margin-bottom: 32rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(108, 92, 231, 0.15);
  background: #ffffff;
}

.big-card {
  padding: 32rpx;
}

.big-author {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.big-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  margin-right: 16rpx;
}

.big-nickname {
  font-size: 24rpx;
  color: #636e72;
  flex: 1;
}

.big-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: #1a1a2e;
  margin-bottom: 24rpx;
}

.big-image {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.big-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.big-tag {
  padding: 4rpx 16rpx;
  background: #f0f0ff;
  color: #6c5ce7;
  font-size: 22rpx;
  border-radius: 999rpx;
}

.action-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #ffffff;
  border-top: 1rpx solid #f2f3f5;
}

.action-group {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  font-size: 28rpx;
  color: #636e72;
  padding: 0 16rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  min-width: 96rpx;
}

.action-btn.active {
  color: #6c5ce7;
}

.action-btn.dislike {
  color: #ff6b6b;
}

.refresh-btn {
  background: linear-gradient(135deg, #6c5ce7 0%, #a29bfe 100%);
  color: #ffffff;
  font-size: 28rpx;
  height: 96rpx;
  border-radius: 999rpx;
  margin: 0 auto 32rpx;
  line-height: 96rpx;
}

.refresh-btn::after {
  border: none;
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 96rpx 0;
  font-size: 28rpx;
  color: #b2bec3;
}
