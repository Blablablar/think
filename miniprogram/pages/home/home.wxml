<!-- pages/home/home.wxml -->
<view class="page">
  <!-- 自定义导航栏 -->
  <navbar type="purple" title="首页"></navbar>

  <!-- 页面内容 -->
  <scroll-view
    scroll-y
    class="content"
    bindscrolltolower="onReachBottom"
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onPullDownRefresh"
  >
    <!-- 搜索框 -->
    <view class="search-bar">
      <image class="search-bar__icon" src="{{searchIcon}}"></image>
      <text class="search-bar__text">搜索灵感、创作者或话题</text>
    </view>

    <!-- Banner 轮播 -->
    <view class="banner-section">
      <swiper
        class="banner-swiper"
        autoplay
        circular
        interval="3500"
        indicator-dots
        indicator-color="rgba(255, 255, 255, 0.4)"
        indicator-active-color="#FFFFFF"
      >
        <swiper-item wx:for="{{banners}}" wx:key="id">
          <view class="banner-item" style="background: {{item.gradient}};">
            <view class="banner-tag">{{item.tag}}</view>
            <view class="banner-title">{{item.title}}</view>
            <view class="banner-meta">{{item.meta}}</view>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <!-- 探索分类 8宫格 -->
    <view class="category-section">
      <view class="section-header">
        <text class="section-header__title">探索分类</text>
        <text class="section-header__more">全部</text>
      </view>
      <view class="category-grid">
        <view
          class="category-item"
          wx:for="{{categories}}"
          wx:key="id"
          bindtap="onCategoryClick"
          data-id="{{item.id}}"
        >
          <view class="category-icon" style="background: {{item.bg}};">
            <text>{{item.icon}}</text>
          </view>
          <view class="category-name">{{item.name}}</view>
        </view>
      </view>
    </view>

    <!-- 热门话题 Chip列表 -->
    <view class="topics-section">
      <view class="section-header">
        <text class="section-header__title">热门话题</text>
        <text class="section-header__more">更多</text>
      </view>
      <view class="topic-list">
        <view
          class="topic-chip"
          wx:for="{{topics}}"
          wx:key="id"
          bindtap="onTopicClick"
          data-id="{{item.id}}"
        >
          <text wx:if="{{item.hot}}" class="topic-chip__hot">🔥</text>
          <text class="topic-chip__text">{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- Feed 分隔标题 -->
    <view class="feed-header">
      <view class="feed-header__line"></view>
      <text class="feed-header__text">为你推荐</text>
      <view class="feed-header__line"></view>
    </view>

    <!-- 推荐创意 Feed流 -->
    <view class="feed-section">
      <block wx:if="{{list.length > 0}}">
        <creativity-card
          wx:for="{{list}}"
          wx:key="_id"
          data="{{item}}"
          bind:click="onCardClick"
          bind:like="onLike"
          bind:favorite="onFavorite"
        ></creativity-card>
        <view class="loading-tip" wx:if="{{loading}}">加载中...</view>
        <view class="loading-tip" wx:if="{{!hasMore && list.length > 0}}">没有更多了</view>
      </block>

      <empty-state
        wx:if="{{list.length === 0 && !loading}}"
        icon="💡"
        text="暂无推荐内容"
        sub-text="快来发布第一个吧"
      ></empty-state>
    </view>
  </scroll-view>
</view>
