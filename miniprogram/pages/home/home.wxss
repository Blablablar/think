/* pages/home/home.wxss */

/* 页面容器 */
.page {
  width: 100%;
  min-height: 100vh;
  background: var(--color-bg-page);
}

/* 页面内容 */
.content {
  height: calc(100vh - 88rpx);  /* 减去导航栏高度 */
}

/* ============================================
   Banner 轮播
   ============================================ */

.banner-section {
  padding: 24rpx 32rpx;
}

.banner-swiper {
  height: 280rpx;    /* 140px */
  border-radius: 24rpx;  /* 12px */
  overflow: hidden;
}

.banner-item {
  width: 100%;
  height: 100%;
  padding: 40rpx 48rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(10px);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #FFFFFF;
  margin-bottom: 16rpx;
  width: fit-content;
}

.banner-title {
  font-size: 40rpx;    /* 20px */
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.banner-meta {
  font-size: 24rpx;    /* 12px */
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* ============================================
   探索分类 8宫格
   ============================================ */

.category-section {
  padding: 24rpx 32rpx;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
}

.category-icon {
  font-size: 64rpx;    /* 32px */
  margin-bottom: 12rpx;
}

.category-name {
  font-size: 24rpx;    /* 12px */
  color: var(--color-text-secondary);
  text-align: center;
}

/* ============================================
   热门话题 Chip列表
   ============================================ */

.topics-section {
  padding: 24rpx 0;
  margin-bottom: 24rpx;
}

.topics-scroll {
  width: 100%;
  white-space: nowrap;
}

.topics-list {
  display: inline-flex;
  padding: 0 32rpx;
  gap: 16rpx;
}

.topic-chip {
  display: inline-flex;
  align-items: center;
  height: 56rpx;      /* 28px */
  padding: 0 28rpx;
  background: #F0F0F0;
  border-radius: 28rpx;
  font-size: 24rpx;    /* 12px */
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.topic-chip--active {
  background: var(--color-primary-light);
  color: var(--color-primary);
}

.topic-chip__icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.topic-chip__text {
  font-size: 24rpx;
}

/* ============================================
   推荐创意 Feed流
   ============================================ */

.feed-section {
  padding: 0 32rpx;
  padding-bottom: 320rpx;  /* 底部留白，适配 tabBar */
}
