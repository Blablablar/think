/* pages/home/home.wxss */

/* 页面容器 */
.page {
  width: 100%;
  min-height: 100vh;
  background: #f5f5f5;
}

/* 页面内容 */
.content {
  height: calc(100vh - 88rpx);
}

/* ============================================
   搜索框 - .search-bar
   ============================================ */
.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;                 /* space-2 8px */
  height: 72rpx;              /* 36px */
  background: #f7f8fa;        /* bg-input */
  border-radius: 36rpx;       /* 18px */
  padding: 0 32rpx;           /* space-4 16px */
  margin: 24rpx 32rpx;        /* space-3 space-4 */
}

.search-bar__icon {
  width: 32rpx;               /* 16px */
  height: 32rpx;
  flex-shrink: 0;
}

.search-bar__text {
  font-size: 28rpx;           /* text-md 14px */
  color: #cccccc;             /* text-placeholder */
}

/* ============================================
   Banner 轮播 - .banner-carousel
   ============================================ */
.banner-section {
  margin: 0 32rpx 24rpx;      /* 0 space-4 space-3 */
}

.banner-swiper {
  height: 280rpx;             /* 140px */
  border-radius: 24rpx;       /* radius-lg 12px */
  overflow: hidden;
}

.banner-item {
  width: 100%;
  height: 100%;
  padding: 32rpx;             /* space-4 16px */
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.banner-tag {
  display: inline-flex;
  align-items: center;
  height: 44rpx;              /* 22px */
  padding: 0 16rpx;           /* space-2 8px */
  background: rgba(255, 255, 255, 0.25);
  border-radius: 22rpx;
  font-size: 22rpx;           /* text-2xs 11px */
  font-weight: 500;
  color: #ffffff;
  margin-bottom: 16rpx;       /* space-2 8px */
  width: fit-content;
}

.banner-title {
  font-size: 34rpx;           /* text-lg 17px */
  font-weight: 700;
  color: #ffffff;
  line-height: 1.25;
  margin-bottom: 8rpx;        /* space-1 4px */
}

.banner-meta {
  font-size: 24rpx;           /* text-sm 12px */
  color: rgba(255, 255, 255, 0.8);
}

/* ============================================
   区块标题 - .section-header
   ============================================ */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;       /* space-3 12px */
}

.section-header__title {
  font-size: 30rpx;           /* text-base 15px */
  font-weight: 600;
  color: #1a1a1a;
}

.section-header__more {
  font-size: 24rpx;           /* text-sm 12px */
  color: #999999;
}

/* ============================================
   探索分类 8宫格 - .category-grid
   ============================================ */
.category-section {
  padding: 0 32rpx;
  margin-bottom: 32rpx;       /* space-4 16px */
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;                 /* space-3 12px */
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;                 /* space-2 8px */
}

.category-icon {
  width: 104rpx;              /* 52px */
  height: 104rpx;
  border-radius: 32rpx;       /* radius-xl 16px */
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;           /* 24px emoji */
}

.category-name {
  font-size: 24rpx;           /* text-sm 12px */
  color: #666666;             /* text-secondary */
}

/* ============================================
   热门话题 - .topic-list
   ============================================ */
.topics-section {
  padding: 0 32rpx;
  margin-bottom: 32rpx;       /* space-4 16px */
}

.topic-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;                 /* space-2 8px */
}

.topic-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;                  /* space-1 4px */
  height: 60rpx;              /* 30px */
  padding: 0 24rpx;           /* space-3 12px */
  border-radius: 30rpx;       /* 15px */
  font-size: 24rpx;           /* text-sm 12px */
  color: #666666;             /* text-secondary */
  background: #ffffff;
  border: 1rpx solid #e8e8e8; /* border-default 0.5px */
}

.topic-chip__hot {
  font-size: 22rpx;           /* text-2xs 11px */
}

.topic-chip__text {
  font-size: 24rpx;
}

/* ============================================
   Feed 分隔标题 - .feed-section-header
   ============================================ */
.feed-header {
  padding: 24rpx 32rpx;       /* space-3 space-4 */
  display: flex;
  align-items: center;
  gap: 16rpx;                 /* space-2 8px */
}

.feed-header__line {
  flex: 1;
  height: 1rpx;               /* 0.5px */
  background: #f0f0f0;        /* border-divider */
}

.feed-header__text {
  font-size: 24rpx;           /* text-sm 12px */
  color: #999999;             /* text-tertiary */
  font-weight: 500;
  flex-shrink: 0;
}

/* ============================================
   推荐创意 Feed流
   ============================================ */
.feed-section {
  padding: 0 32rpx;
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

.loading-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  padding: 32rpx 0;
}
