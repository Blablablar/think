/* pages/user/index.wxss */
.page {
  min-height: 100vh;
  background: #f8f9fe;
  display: flex;
  flex-direction: column;
}

.profile-card {
  background: linear-gradient(180deg, #6c5ce7 0%, #a29bfe 100%);
  padding: 48rpx 32rpx 32rpx;
  position: relative;
  overflow: hidden;
}

.profile-card::after {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.profile-row {
  display: flex;
  align-items: center;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 999rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 32rpx;
  flex-shrink: 0;
}

.avatar-default {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #dfe6e9;
  font-size: 64rpx;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.join-date {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.stats-row {
  display: flex;
  gap: 48rpx;
  margin-top: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 4rpx;
}

.follow-btn {
  margin-top: 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #ffffff;
  color: #6c5ce7;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 999rpx;
  padding: 0;
}

.follow-btn::after {
  border: none;
}

.follow-btn.followed {
  background: rgba(255, 255, 255, 0.25);
  color: #ffffff;
}

.list {
  flex: 1;
  padding: 24rpx 32rpx 120rpx;
  height: calc(100vh - 420rpx);
  box-sizing: border-box;
}

.loading-tip {
  text-align: center;
  padding: 24rpx 0;
  font-size: 24rpx;
  color: #b2bec3;
}
