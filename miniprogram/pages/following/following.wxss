/* pages/following/following.wxss */

/* 页面容器 */
.page {
  width: 100%;
  height: 100vh;
  background: var(--color-bg-page);
  display: flex;
  flex-direction: column;
}

/* ============================================
   Tab 切换
   ============================================ */

.tabs {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;      /* 44px */
  background: var(--color-primary);
  padding: 0 160rpx;   /* 80px */
}

.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  position: relative;
}

.tab__text {
  font-size: var(--font-size-lg);
  color: rgba(255, 255, 255, 0.7);
  font-weight: var(--font-weight-medium);
}

.tab--active .tab__text {
  color: #FFFFFF;
  font-weight: var(--font-weight-semibold);
}

.tab__indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;      /* 24px */
  height: 6rpx;       /* 3px */
  background: #FFFFFF;
  border-radius: 3rpx;
}

/* ============================================
   内容区域
   ============================================ */

.content {
  flex: 1;
  width: 100%;
}

.swiper-item {
  width: 100%;
  height: 100%;
}

.list {
  height: 100%;
  padding: var(--spacing-lg);
  padding-bottom: 320rpx;  /* 底部留白，适配 tabBar */
  box-sizing: border-box;
}
