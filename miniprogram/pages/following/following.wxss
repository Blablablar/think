/* pages/following/following.wxss */

/* 页面容器 */
.page {
  width: 100%;
  height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* ============================================
   Sub Tabs - 关注 / 收藏（白色背景，紫色指示器）
   ============================================ */
.tabs {
  display: flex;
  gap: 48rpx;                 /* space-6 24px */
  padding: 24rpx 32rpx;       /* space-3 space-4 */
  background: #ffffff;
}

.tab {
  position: relative;
  font-size: 30rpx;           /* text-base 15px */
  font-weight: 500;
  color: #666666;             /* text-secondary */
  padding-bottom: 16rpx;      /* space-2 8px */
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab--active {
  color: #534ab7;             /* brand-purple-500 */
  font-weight: 600;
}

.tab__indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;               /* 20px */
  height: 6rpx;               /* 3px */
  border-radius: 3rpx;
  background: #534ab7;
}

/* ============================================
   内容区域
   ============================================ */
.content {
  flex: 1;
  width: 100%;
}

.swiper-item {
  width: 100%;
  height: 100%;
}

.list {
  height: 100%;
  padding: 24rpx 32rpx;
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.loading-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  padding: 32rpx 0;
}
