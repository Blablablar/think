<!-- pages/my/index.wxml -->
<view class="page">
  <!-- 用户信息卡 -->
  <view class="profile-card">
    <view class="msg-icon" bindtap="onMsgClick" wx:if="{{hasLogin}}">
      <text>🔔</text>
      <view class="badge" wx:if="{{unreadCount > 0}}">{{unreadCount > 99 ? '99+' : unreadCount}}</view>
    </view>

    <!-- 已登录：显示用户信息 -->
    <view class="profile-info" wx:if="{{hasLogin}}" bindtap="onEditProfile">
      <image wx:if="{{userInfo.avatarUrl}}" class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <view wx:else class="avatar avatar-default">👤</view>
      <view class="profile-text">
        <view class="nickname">{{userInfo.nickName}}</view>
        <view class="profile-stats">
          <view class="stat-item">
            <view class="stat-num">{{publishedCount}}</view>
            <view class="stat-label">发布</view>
          </view>
          <view class="stat-item">
            <view class="stat-num">{{implCount}}</view>
            <view class="stat-label">实现</view>
          </view>
          <view class="stat-item">
            <view class="stat-num">{{likeCount}}</view>
            <view class="stat-label">获赞</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 未登录：显示一键登录 -->
    <view class="login-area" wx:else>
      <view class="login-avatar">👤</view>
      <view class="login-tip">登录后查看你的创意世界</view>
      <button class="login-btn" bindtap="onLogin">
        <text class="login-icon">💚</text>
        <text>微信一键登录</text>
      </button>
    </view>
  </view>

  <!-- 编辑资料弹窗 -->
  <view class="edit-mask" wx:if="{{editVisible}}" bindtap="onCloseEdit">
    <view class="edit-dialog" catchtap>
      <view class="edit-title">编辑个人资料</view>
      <button class="edit-avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onEditChooseAvatar">
        <image wx:if="{{editAvatarUrl}}" class="edit-avatar-img" src="{{editAvatarUrl}}" mode="aspectFill"></image>
        <view wx:else class="edit-avatar-placeholder">
          <view class="edit-avatar-add">+</view>
          <view class="edit-avatar-tip">点击选择头像</view>
        </view>
      </button>
      <input class="edit-nickname" type="nickname" placeholder="请输入昵称" value="{{editNickName}}" bindinput="onEditNicknameInput" />
      <view class="edit-actions">
        <button class="edit-cancel-btn" bindtap="onCloseEdit">取消</button>
        <button class="edit-save-btn" bindtap="onSaveProfile" loading="{{savingProfile}}">保存</button>
      </view>
    </view>
  </view>

  <!-- 主 Tab 切换 -->
  <scroll-view scroll-x enable-flex class="tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab {{activeTab === item.key ? 'active' : ''}}"
      bindtap="onTabChange"
      data-key="{{item.key}}"
    >{{item.label}}</view>
  </scroll-view>

  <!-- 互动子 Tab -->
  <view class="sub-tabs" wx:if="{{activeTab === 'interaction'}}">
    <view
      class="sub-tab {{interactionTab === 'liked' ? 'active' : ''}}"
      bindtap="onInteractionTabChange"
      data-key="liked"
    >我点赞的</view>
    <view
      class="sub-tab {{interactionTab === 'commented' ? 'active' : ''}}"
      bindtap="onInteractionTabChange"
      data-key="commented"
    >我评论的</view>
  </view>

  <!-- 列表 -->
  <scroll-view scroll-y enable-flex class="list">
    <block wx:if="{{loading}}">
      <view class="loading-tip">加载中...</view>
    </block>

    <block wx:elif="{{activeTab === 'implemented'}}">
      <block wx:if="{{implList.length > 0}}">
        <view class="impl-card" wx:for="{{implList}}" wx:key="_id">
          <view class="impl-header">
            <view class="impl-title ellipsis">创意成果</view>
            <view class="impl-version">v{{item.version}}</view>
          </view>
          <view class="impl-desc ellipsis-2">{{item.description}}</view>
          <view class="impl-actions">
            <view class="impl-action" bindtap="onEditImpl" data-id="{{item._id}}">编辑</view>
            <view class="impl-action danger" bindtap="onDeleteImpl" data-id="{{item._id}}">删除</view>
          </view>
        </view>
      </block>
      <empty-state
        wx:else
        icon="🎯"
        text="还没有实现成果"
        sub-text="去认领一个创意吧"
      ></empty-state>
    </block>

    <block wx:else>
      <block wx:if="{{list.length > 0}}">
        <creativity-card
          wx:for="{{list}}"
          wx:key="_id"
          data="{{item}}"
          show-author="{{activeTab !== 'published'}}"
          bind:click="onCardClick"
        ></creativity-card>
      </block>
      <empty-state
        wx:else
        icon="📭"
        text="暂无数据"
      ></empty-state>
    </block>
  </scroll-view>
</view>
