/* pages/my/index.wxss */
.page {
  min-height: 100vh;
  background: #f8f9fe;
}

.profile-card {
  background: linear-gradient(180deg, #6c5ce7 0%, #a29bfe 100%);
  padding: 48rpx 32rpx;
  position: relative;
  overflow: hidden;
}

.profile-card::after {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.msg-icon {
  position: absolute;
  top: 24rpx;
  right: 32rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 6rpx;
  border-radius: 999rpx;
  background: #ff6b6b;
  color: #ffffff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-info {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
}

/* 未登录区域 */
.login-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 16rpx;
}

.login-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.login-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 32rpx;
}

.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #ffffff;
  color: #6c5ce7;
  font-size: 28rpx;
  font-weight: 500;
  height: 88rpx;
  padding: 0 64rpx;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  line-height: 88rpx;
}

.login-btn::after {
  border: none;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 999rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 32rpx;
  flex-shrink: 0;
}

.avatar-default {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #dfe6e9;
  font-size: 64rpx;
}

/* 编辑资料弹窗 */
.edit-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-dialog {
  width: 600rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.edit-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 32rpx;
}

.edit-avatar-btn {
  width: 160rpx;
  height: 160rpx;
  padding: 0;
  margin-bottom: 32rpx;
  border-radius: 999rpx;
  background: #f2f3f5;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  line-height: normal;
}

.edit-avatar-btn::after {
  border: none;
}

.edit-avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 999rpx;
}

.edit-avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #b2bec3;
}

.edit-avatar-add {
  font-size: 56rpx;
  line-height: 1;
  margin-bottom: 4rpx;
}

.edit-avatar-tip {
  font-size: 20rpx;
}

.edit-nickname {
  width: 100%;
  height: 80rpx;
  background: #f8f9fe;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  margin-bottom: 32rpx;
  box-sizing: border-box;
}

.edit-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.edit-cancel-btn {
  flex: 1;
  height: 80rpx;
  background: #f2f3f5;
  color: #636e72;
  font-size: 28rpx;
  border-radius: 999rpx;
  line-height: 80rpx;
  padding: 0;
}

.edit-cancel-btn::after {
  border: none;
}

.edit-save-btn {
  flex: 1;
  height: 80rpx;
  background: linear-gradient(135deg, #6c5ce7 0%, #a29bfe 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 999rpx;
  line-height: 80rpx;
  padding: 0;
}

.edit-save-btn::after {
  border: none;
}

.profile-text {
  flex: 1;
  min-width: 0;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.profile-stats {
  display: flex;
  gap: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.tabs {
  display: flex;
  background: #ffffff;
  border-bottom: 1rpx solid #f2f3f5;
  padding: 0 32rpx;
  white-space: nowrap;
}

.tab {
  display: inline-block;
  padding: 24rpx 16rpx;
  font-size: 24rpx;
  color: #636e72;
  position: relative;
  margin-right: 24rpx;
}

.tab.active {
  color: #6c5ce7;
  font-weight: 500;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #6c5ce7;
  border-radius: 999rpx;
}

.sub-tabs {
  display: flex;
  background: #ffffff;
  padding: 16rpx 32rpx;
  gap: 24rpx;
}

.sub-tab {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: #b2bec3;
  border-radius: 999rpx;
  background: #f2f3f5;
}

.sub-tab.active {
  background: #f0f0ff;
  color: #6c5ce7;
  font-weight: 500;
}

.list {
  padding: 24rpx 32rpx 120rpx;
  height: calc(100vh - 460rpx);
  box-sizing: border-box;
}

.impl-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.impl-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.impl-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a2e;
  flex: 1;
}

.impl-version {
  font-size: 22rpx;
  color: #6c5ce7;
  background: #f0f0ff;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  margin-left: 16rpx;
}

.impl-desc {
  font-size: 24rpx;
  color: #636e72;
  line-height: 1.5;
}

.impl-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
  border-top: 1rpx solid #f2f3f5;
  padding-top: 16rpx;
}

.impl-action {
  font-size: 24rpx;
  color: #6c5ce7;
}

.impl-action.danger {
  color: #ff6b6b;
}
