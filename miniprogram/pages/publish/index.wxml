<!-- pages/publish/index.wxml -->
<view class="page">
  <!-- 自定义导航栏 -->
  <navbar
    type="purple"
    title="发布创意"
    right-text="取消"
    bind:rightClick="onCancel"
  ></navbar>

  <scroll-view scroll-y class="content" enhanced show-scrollbar="{{false}}">
    <!-- 正文输入区 -->
    <view class="input-area">
      <textarea
        class="text-input"
        placeholder="记录你的灵感..."
        placeholder-class="placeholder"
        value="{{content}}"
        bindinput="onContentInput"
        maxlength="{{maxContent}}"
        auto-height
        cursor-spacing="100"
      ></textarea>

      <!-- 已插入的图片 -->
      <view class="image-list" wx:if="{{images.length > 0}}">
        <view class="image-item" wx:for="{{images}}" wx:key="index">
          <image class="image-preview" src="{{item}}" mode="aspectFill"></image>
          <view class="image-overlay"></view>
          <view class="image-delete" catchtap="onDeleteImage" data-index="{{index}}">✕</view>
        </view>

        <!-- 插入图片入口 -->
        <view class="add-image-btn" wx:if="{{images.length < 9}}" bindtap="onChooseImage">
          <view class="add-icon">+</view>
          <view class="add-text">插入图片</view>
        </view>
      </view>

      <!-- 无图片时的插入图片入口 -->
      <view class="insert-image" wx:if="{{images.length === 0}}" bindtap="onChooseImage">
        <view class="insert-line"></view>
        <view class="insert-text">点击插入图片</view>
        <view class="insert-line"></view>
      </view>
    </view>

    <!-- 分类标签选择 -->
    <view class="tag-section">
      <view class="tag-list">
        <view
          class="tag-item {{selectedTags.indexOf(item) > -1 ? 'tag-item--active' : ''}}"
          wx:for="{{tagOptions}}"
          wx:key="*this"
          bindtap="onToggleTag"
          data-tag="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </view>

    <!-- 草稿提示 -->
    <view class="draft-tip" wx:if="{{showDraftTip}}">
      <text>已自动保存草稿</text>
    </view>
  </scroll-view>

  <!-- 底部发布按钮 -->
  <view class="bottom-bar">
    <button
      class="publish-btn"
      bindtap="onPublish"
      loading="{{publishing}}"
      disabled="{{publishing}}"
    >{{publishing ? '发布中...' : '发布创意'}}</button>
  </view>
</view>
