<!-- pages/publish/index.wxml -->
<view class="page">
  <!-- 自定义导航栏 -->
  <navbar
    type="purple"
    title="发布创意"
    right-text="取消"
    bind:rightClick="onCancel"
  ></navbar>

  <scroll-view scroll-y class="content" enhanced show-scrollbar="{{false}}">
    <!-- 标题字段 -->
    <view class="field">
      <view class="field__label">
        <view class="field__dot"></view>
        <text>标题</text>
      </view>
      <input
        class="title-input"
        placeholder="给你的创意起个名字吧"
        placeholder-class="placeholder"
        value="{{title}}"
        bindinput="onTitleInput"
        maxlength="{{maxTitle}}"
      />
      <view class="field__hint field__hint--right">
        <text>{{title.length}}/{{maxTitle}}</text>
      </view>
    </view>

    <!-- 正文字段 -->
    <view class="field">
      <view class="field__label">
        <view class="field__dot"></view>
        <text>正文</text>
      </view>
      <view class="editor">
        <textarea
          class="editor__input"
          placeholder="记录你的灵感..."
          placeholder-class="placeholder"
          value="{{content}}"
          bindinput="onContentInput"
          maxlength="{{maxContent}}"
          auto-height
          cursor-spacing="100"
        ></textarea>

        <!-- 已插入的图片 -->
        <view class="image-list" wx:if="{{images.length > 0}}">
          <view class="image-item" wx:for="{{images}}" wx:key="index">
            <image class="image-preview" src="{{item}}" mode="aspectFill"></image>
            <view class="image-delete" catchtap="onDeleteImage" data-index="{{index}}">✕</view>
          </view>
        </view>

        <!-- 插入图片入口 -->
        <view class="inline-add" wx:if="{{images.length < 9}}" bindtap="onChooseImage">
          <text class="inline-add__icon">+</text>
          <text>在此处插入图片</text>
        </view>
      </view>
      <view class="field__hint">
        <text wx:if="{{showDraftTip}}">已自动保存草稿</text>
        <text class="field__hint--right">{{content.length}}/{{maxContent}}</text>
      </view>
    </view>

    <!-- 分类标签字段 -->
    <view class="field">
      <view class="field__label">
        <view class="field__dot"></view>
        <text>分类标签</text>
      </view>
      <view class="tag-grid">
        <view
          class="tag-pill {{selectedTags.indexOf(item) > -1 ? 'tag-pill--selected' : ''}}"
          wx:for="{{tagOptions}}"
          wx:key="*this"
          bindtap="onToggleTag"
          data-tag="{{item}}"
        >{{item}}</view>
      </view>
      <view class="field__hint">
        <text>为创意添加一个分类，更容易被发现</text>
      </view>
    </view>
  </scroll-view>

  <!-- 底部发布按钮 -->
  <view class="bottom-bar">
    <button
      class="publish-btn"
      bindtap="onPublish"
      loading="{{publishing}}"
      disabled="{{publishing}}"
    >{{publishing ? '发布中...' : '发布创意'}}</button>
  </view>
</view>
