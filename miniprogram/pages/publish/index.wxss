/* pages/publish/index.wxss */

.page {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.content {
  flex: 1;
  padding: 24rpx 32rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  height: calc(100vh - 200rpx);
  box-sizing: border-box;
}

/* 正文输入区 */
.input-area {
  background: #f5f5f5;
  border-radius: 0;
  padding: 32rpx 0;
  margin-bottom: 32rpx;
}

.text-input {
  width: 100%;
  min-height: 300rpx;
  font-size: 32rpx;
  line-height: 1.8;
  color: #1a1a2e;
  background: transparent;
  padding: 0;
}

.placeholder {
  color: #b2bec3;
  font-size: 32rpx;
}

/* 已插入图片 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 32rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-preview {
  width: 100%;
  height: 100%;
}

.image-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(83, 74, 183, 0.1) 0%, transparent 100%);
}

.image-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* 插入图片入口 */
.add-image-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #d1d5db;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #ffffff;
}

.add-icon {
  font-size: 48rpx;
  color: #6c5ce7;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 22rpx;
  color: #6c5ce7;
}

/* 无图片时的插入图片入口 */
.insert-image {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 48rpx;
  padding: 32rpx 0;
}

.insert-line {
  flex: 1;
  height: 2rpx;
  background: #e5e6eb;
}

.insert-text {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #6c5ce7;
}

/* 分类标签选择 */
.tag-section {
  margin-bottom: 32rpx;
}

.tag-list {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
  padding: 8rpx 0;
}

.tag-list::-webkit-scrollbar {
  display: none;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  padding: 0 28rpx;
  border-radius: 28rpx;
  background: #f2f3f5;
  color: #636e72;
  font-size: 24rpx;
  flex-shrink: 0;
}

.tag-item--active {
  background: rgba(108, 92, 231, 0.1);
  color: #534ab7;
  font-weight: 500;
}

/* 草稿提示 */
.draft-tip {
  text-align: center;
  padding: 24rpx 0;
  font-size: 22rpx;
  color: #b2bec3;
}

/* 底部发布按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.publish-btn {
  width: 100%;
  height: 92rpx;
  background: #534ab7;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 0;
  border: none;
  line-height: 92rpx;
  padding: 0;
}

.publish-btn::after {
  border: none;
}

.publish-btn[loading] {
  opacity: 0.7;
}
