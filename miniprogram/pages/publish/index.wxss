/* pages/publish/index.wxss */

.page {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.content {
  flex: 1;
  padding: 32rpx;
  padding-bottom: calc(320rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ============================================
   字段 - .field
   ============================================ */
.field {
  margin-bottom: 48rpx;       /* space-6 24px */
}

.field__label {
  display: flex;
  align-items: center;
  gap: 16rpx;                 /* space-2 8px */
  font-size: 28rpx;           /* text-md 14px */
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;       /* space-3 12px */
}

.field__dot {
  width: 12rpx;               /* 6px */
  height: 12rpx;
  border-radius: 50%;
  background: #534ab7;
  flex-shrink: 0;
}

.field__hint {
  font-size: 24rpx;           /* text-sm 12px */
  color: #999999;
  margin-top: 16rpx;          /* space-2 8px */
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.field__hint--right {
  justify-content: flex-end;
}

.placeholder {
  color: #cccccc;
}

/* ============================================
   标题输入 - .input-ghost--title
   ============================================ */
.title-input {
  width: 100%;
  height: 88rpx;              /* 44px */
  padding: 0 32rpx;           /* space-4 16px */
  background: #f7f8fa;        /* bg-input */
  border-radius: 16rpx;       /* radius-md 8px */
  font-size: 30rpx;           /* text-base 15px */
  font-weight: 600;
  color: #1a1a1a;
  box-sizing: border-box;
}

/* ============================================
   正文编辑器 - .content-editor
   ============================================ */
.editor {
  background: #f7f8fa;        /* bg-input */
  border-radius: 16rpx;       /* radius-md 8px */
  padding: 32rpx;             /* space-4 16px */
  display: flex;
  flex-direction: column;
  gap: 24rpx;                 /* space-3 12px */
}

.editor__input {
  width: 100%;
  min-height: 240rpx;
  font-size: 30rpx;           /* text-base 15px */
  line-height: 1.6;           /* leading-relaxed */
  color: #1a1a1a;
}

/* 已插入图片 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 100%;
  height: 320rpx;             /* 16:10 比例 */
  border-radius: 16rpx;
  overflow: hidden;
}

.image-preview {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;               /* 24px */
  height: 48rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* 插入图片入口 - .inline-add */
.inline-add {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;                  /* space-1 4px */
  height: 80rpx;              /* 40px */
  border-radius: 16rpx;
  border: 2rpx dashed #e8e8e8;
  background: transparent;
  color: #999999;
  font-size: 24rpx;           /* text-sm 12px */
}

.inline-add__icon {
  font-size: 32rpx;
}

/* ============================================
   分类标签 - .tag-grid / .tag-pill
   ============================================ */
.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;                 /* space-2 8px */
}

.tag-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;              /* 28px */
  padding: 0 24rpx;           /* space-3 12px */
  border-radius: 28rpx;       /* 14px */
  font-size: 24rpx;           /* text-sm 12px */
  background: #f0eff5;        /* bg-tag */
  color: #666666;             /* text-secondary */
}

.tag-pill--selected {
  background: #f5f3ff;        /* brand-purple-50 */
  color: #534ab7;             /* brand-purple-500 */
  font-weight: 500;
}

/* ============================================
   底部发布按钮 - .publish-bottom
   ============================================ */
.bottom-bar {
  position: fixed;
  bottom: calc(100rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;       /* space-3 space-4 */
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  z-index: 100;
}

.publish-btn {
  width: 100%;
  height: 92rpx;              /* 46px */
  background: #534ab7;
  color: #ffffff;
  font-size: 30rpx;           /* text-base 15px */
  font-weight: 600;
  border-radius: 24rpx;       /* radius-lg 12px */
  border: none;
  line-height: 92rpx;
  padding: 0;
  letter-spacing: 1rpx;
}

.publish-btn::after {
  border: none;
}

.publish-btn[loading] {
  opacity: 0.7;
}

.publish-btn[disabled] {
  opacity: 0.7;
}
