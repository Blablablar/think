/* pages/hot/index.wxss */
.page {
  min-height: 100vh;
  background: #f8f9fe;
}

.header {
  background: linear-gradient(135deg, #ff6b6b 0%, #ffa8a8 100%);
  padding: 32rpx 32rpx 48rpx;
  position: relative;
  overflow: hidden;
}

.header::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: -30rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.fire-icon {
  font-size: 40rpx;
}

.header-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

.list {
  padding: 24rpx 32rpx 120rpx;
  height: calc(100vh - 220rpx);
  box-sizing: border-box;
}

.rank-card {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.rank-num {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  flex-shrink: 0;
  background: #b2bec3;
}

.rank-num.top1 {
  background: linear-gradient(135deg, #ffd700 0%, #ffb700 100%);
}

.rank-num.top2 {
  background: linear-gradient(135deg, #c0c0c0 0%, #a8a8a8 100%);
}

.rank-num.top3 {
  background: linear-gradient(135deg, #cd7f32 0%, #b87333 100%);
}

.card-wrapper {
  flex: 1;
  min-width: 0;
}

.hot-bar {
  height: 8rpx;
  background: #f2f3f5;
  border-radius: 999rpx;
  margin-top: 16rpx;
  overflow: hidden;
}

.hot-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff6b6b 0%, #ffd93d 100%);
  border-radius: 999rpx;
  transition: width 0.35s ease;
}
