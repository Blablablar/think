/* pages/messages/index.wxss */

.page {
  min-height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
}

/* ============================================
   双Tab切换 - .msg-tabs（白色背景，紫色下划线）
   ============================================ */
.tab-bar {
  display: flex;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  font-size: 30rpx;           /* text-base 15px */
  font-weight: 500;
  color: #999999;             /* text-tertiary */
  position: relative;
}

.tab-item--active {
  color: #1a1a1a;             /* text-primary */
  font-weight: 600;
}

.tab-item--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;               /* 20px */
  height: 6rpx;               /* 3px */
  border-radius: 4rpx;
  background: #534ab7;
}

.tab-badge {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #fa5151;        /* color-error */
  margin-left: 8rpx;
}

/* ============================================
   内容区
   ============================================ */
.content {
  flex: 1;
  height: calc(100vh - 300rpx);
  box-sizing: border-box;
}

/* ============================================
   时间分组 - .time-group
   ============================================ */
.time-group {
  padding: 0 32rpx;
  font-size: 22rpx;           /* text-xs 11px */
  font-weight: 500;
  color: #999999;             /* text-tertiary */
  padding-top: 32rpx;         /* space-4 16px */
  padding-bottom: 16rpx;      /* space-2 8px */
  letter-spacing: 0.6rpx;
}

/* ============================================
   消息项 - 列表样式（border-bottom 分隔）
   ============================================ */
.msg-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;                 /* space-3 12px */
  padding: 24rpx 32rpx;       /* space-3 space-4 */
  border-bottom: 1rpx solid #f0f0f0;
  background: #ffffff;
  position: relative;
}

.msg-item--unread {
  background: transparent;
}

/* 未读紫点 */
.unread-dot {
  position: absolute;
  left: 16rpx;
  top: 40rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #534ab7;
}

.msg-item--unread .msg-body {
  padding-left: 0;
}

/* 头像 */
.msg-avatar {
  width: 72rpx;               /* 36px */
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 2rpx;
}

/* 多头像 */
.msg-avatars {
  display: flex;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.msg-avatar-small {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid #ffffff;
  margin-left: -16rpx;
}

.msg-avatar-small:first-child {
  margin-left: 0;
}

/* 消息体 */
.msg-body {
  flex: 1;
  min-width: 0;
}

.msg-title {
  font-size: 28rpx;           /* text-md 14px */
  color: #1a1a1a;
  line-height: 1.45;
  margin-bottom: 8rpx;
}

.msg-name {
  font-weight: 600;
  color: #1a1a1a;
  margin-right: 8rpx;
}

.msg-action {
  color: #666666;             /* text-secondary */
}

.msg-preview {
  font-size: 24rpx;           /* text-sm 12px */
  color: #999999;             /* text-tertiary */
  background: #f0eff5;        /* bg-tag */
  padding: 16rpx 24rpx;       /* space-2 space-3 */
  border-radius: 8rpx;        /* radius-sm 4px */
  margin-top: 12rpx;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.msg-badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  background: #e6f9ef;        /* wechat-green-50 */
  color: #07c160;             /* wechat-green-500 */
  font-size: 20rpx;
  border-radius: 4rpx;
  margin-top: 12rpx;
}

.msg-time {
  font-size: 24rpx;           /* text-sm 12px */
  color: #bfbfbf;             /* text-quaternary */
  margin-top: 8rpx;           /* space-1 4px */
}

/* ============================================
   系统消息
   ============================================ */
.msg-item--system {
  align-items: flex-start;
}

.system-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f5f3ff;        /* brand-purple-50 */
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.msg-desc {
  font-size: 24rpx;           /* text-sm 12px */
  color: #666666;             /* text-secondary */
  margin-top: 8rpx;
  line-height: 1.6;
}

/* ============================================
   空状态
   ============================================ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;           /* text-md 14px */
  color: #999999;
}

/* 加载提示 */
.loading-tip {
  text-align: center;
  padding: 24rpx 0;
  font-size: 24rpx;
  color: #999999;
}
