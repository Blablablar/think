/* pages/messages/index.wxss */

.page {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 双Tab切换 */
.tab-bar {
  display: flex;
  background: #ffffff;
  border-bottom: 1rpx solid #f2f3f5;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  font-size: 28rpx;
  color: #636e72;
  position: relative;
}

.tab-item--active {
  color: #534ab7;
  font-weight: 600;
}

.tab-item--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #534ab7;
  border-radius: 3rpx;
}

.tab-badge {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ff6b6b;
  margin-left: 8rpx;
}

/* 内容区 */
.content {
  flex: 1;
  height: calc(100vh - 300rpx);
  box-sizing: border-box;
}

/* 时间分组 */
.time-group {
  padding: 24rpx 32rpx 16rpx;
  font-size: 22rpx;
  color: #b2bec3;
}

/* 消息项 */
.msg-item {
  display: flex;
  align-items: flex-start;
  background: #ffffff;
  padding: 24rpx 32rpx;
  margin: 0 24rpx 16rpx;
  border-radius: 16rpx;
  position: relative;
}

.msg-item--unread {
  background: rgba(83, 74, 183, 0.05);
}

/* 未读蓝点 */
.unread-dot {
  position: absolute;
  left: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #534ab7;
}

.msg-item--unread .msg-body {
  padding-left: 24rpx;
}

/* 头像 */
.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

/* 多头像 */
.msg-avatars {
  display: flex;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.msg-avatar-small {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid #ffffff;
  margin-left: -16rpx;
}

.msg-avatar-small:first-child {
  margin-left: 0;
}

/* 消息体 */
.msg-body {
  flex: 1;
  min-width: 0;
}

.msg-title {
  font-size: 28rpx;
  color: #1a1a2e;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.msg-name {
  font-weight: 600;
  margin-right: 8rpx;
}

.msg-action {
  color: #636e72;
}

.msg-preview {
  font-size: 24rpx;
  color: #636e72;
  background: #f8f9fe;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  margin-top: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.msg-badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: rgba(76, 175, 80, 0.1);
  color: #4caf50;
  font-size: 20rpx;
  border-radius: 4rpx;
  margin-top: 8rpx;
}

.msg-time {
  font-size: 22rpx;
  color: #b2bec3;
  margin-top: 8rpx;
}

/* 系统消息 */
.msg-item--system {
  align-items: flex-start;
}

.system-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f8f9fe;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.msg-desc {
  font-size: 24rpx;
  color: #636e72;
  margin-top: 8rpx;
  line-height: 1.6;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #b2bec3;
}

/* 加载提示 */
.loading-tip {
  text-align: center;
  padding: 24rpx 0;
  font-size: 24rpx;
  color: #b2bec3;
}
