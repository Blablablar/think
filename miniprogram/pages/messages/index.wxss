.page {
  min-height: 100vh;
  background: #f8f9fe;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.sub-text {
  font-size: 28rpx;
  color: #b2bec3;
}

.bottom-spacer {
  height: 160rpx;
}
