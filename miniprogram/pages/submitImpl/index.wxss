/* pages/submitImpl/index.wxss */
.page {
  min-height: 100vh;
  background: #f8f9fe;
  display: flex;
  flex-direction: column;
}

.content {
  flex: 1;
  padding: 24rpx 32rpx;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  height: calc(100vh - 100rpx);
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.section-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.text-area {
  width: 100%;
  min-height: 240rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #1a1a2e;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #b2bec3;
  margin-top: 16rpx;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.image-preview {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  z-index: 2;
}

.add-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  border: 2rpx dashed #e5e6eb;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 40rpx;
  color: #b2bec3;
  margin-bottom: 4rpx;
}

.add-text {
  font-size: 22rpx;
  color: #b2bec3;
}

.video-wrap {
  position: relative;
  width: 100%;
}

.video-preview {
  width: 100%;
  height: 400rpx;
  border-radius: 8rpx;
  background: #000;
}

.video-delete {
  top: 16rpx;
  right: 16rpx;
}

.add-video {
  width: 100%;
  height: 240rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #e5e6eb;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tip {
  font-size: 22rpx;
  color: #b2bec3;
  text-align: center;
  padding: 16rpx 0;
}

.bottom-spacer {
  height: 40rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #6c5ce7 0%, #a29bfe 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 999rpx;
  line-height: 96rpx;
  padding: 0;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.7;
}
