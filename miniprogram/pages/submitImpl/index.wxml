<!-- pages/submitImpl/index.wxml -->
<view class="page">
  <scroll-view scroll-y class="content">
    <!-- 成果描述 -->
    <view class="card">
      <view class="section-label">成果描述</view>
      <textarea
        class="text-area"
        placeholder="描述你的实现过程、技术方案或亮点..."
        value="{{description}}"
        bindinput="onDescInput"
        maxlength="{{maxDesc}}"
        auto-height
      ></textarea>
      <view class="char-count">{{description.length}}/{{maxDesc}}</view>
    </view>

    <!-- 截图上传 -->
    <view class="card">
      <view class="section-label">成果截图（最多9张）</view>
      <view class="image-grid">
        <view class="image-item" wx:for="{{screenshots}}" wx:key="*this">
          <image
            class="image-preview"
            src="{{item}}"
            mode="aspectFill"
            bindtap="onPreviewImage"
            data-index="{{index}}"
          ></image>
          <view class="image-delete" catchtap="onDeleteImage" data-index="{{index}}">✕</view>
        </view>
        <view class="add-image" wx:if="{{screenshots.length < 9}}" bindtap="onChooseImage">
          <view class="add-icon">+</view>
          <view class="add-text">添加截图</view>
        </view>
      </view>
    </view>

    <!-- 视频上传 -->
    <view class="card">
      <view class="section-label">演示视频（不超过30秒）</view>
      <block wx:if="{{videoTempPath}}">
        <view class="video-wrap">
          <video class="video-preview" src="{{videoTempPath}}" controls></video>
          <view class="image-delete video-delete" catchtap="onDeleteVideo">✕</view>
        </view>
      </block>
      <block wx:elif="{{videoUrl}}">
        <view class="video-wrap">
          <video class="video-preview" src="{{videoUrl}}" controls></video>
          <view class="image-delete video-delete" catchtap="onDeleteVideo">✕</view>
        </view>
      </block>
      <view class="add-video" wx:else bindtap="onChooseVideo">
        <view class="add-icon">🎬</view>
        <view class="add-text">添加视频</view>
      </view>
    </view>

    <view class="tip">视频提交后将进行异步审核，审核通过后才会公开展示</view>
    <view class="bottom-spacer"></view>
  </scroll-view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <button
      class="submit-btn"
      bindtap="onSubmit"
      loading="{{submitting}}"
      disabled="{{submitting}}"
    >{{submitting ? '提交中...' : (mode === 'edit' ? '保存修改' : '提交成果')}}</button>
  </view>
</view>
