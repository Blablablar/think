/* pages/today/index.wxss */
.page {
  min-height: 100vh;
  background: #f8f9fe;
}

.header {
  background: linear-gradient(180deg, #6c5ce7 0%, #a29bfe 100%);
  padding: 32rpx 32rpx 48rpx;
  position: relative;
  overflow: hidden;
}

.header::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.header-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 32rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 999rpx;
  padding: 16rpx 32rpx;
  height: 72rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.search-icon {
  font-size: 28rpx;
  color: #b2bec3;
  margin-right: 16rpx;
}

.search-text {
  font-size: 24rpx;
  color: #b2bec3;
  flex: 1;
}

.list {
  padding: 0 32rpx 120rpx;
  height: calc(100vh - 280rpx);
  box-sizing: border-box;
}
