/* pages/detail/index.wxss */

.page {
  min-height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
}

/* 加载提示 */
.loading-tip {
  text-align: center;
  padding: 120rpx 0;
  font-size: 28rpx;
  color: #b2bec3;
}

/* 滚动区域 */
.scroll-area {
  flex: 1;
  height: calc(100vh - 120rpx);
  box-sizing: border-box;
}

/* 作者信息 */
.author-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f2f3f5;
}

.author-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.author-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.author-meta {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.author-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 4rpx;
}

.author-time {
  font-size: 22rpx;
  color: #b2bec3;
}

/* 关注按钮 */
.follow-btn {
  padding: 8rpx 28rpx;
  background: #534ab7;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.follow-btn--active {
  background: #f2f3f5;
  color: #636e72;
}

/* 推荐理由标签 */
.recommend-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: rgba(83, 74, 183, 0.08);
  color: #534ab7;
  font-size: 22rpx;
  margin: 0 32rpx 24rpx;
  border-radius: 8rpx;
}

/* 标题 */
.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1.5;
  padding: 0 32rpx 24rpx;
}

/* 正文内容 */
.detail-content {
  font-size: 30rpx;
  color: #1a1a2e;
  line-height: 1.8;
  padding: 0 32rpx 32rpx;
  white-space: pre-wrap;
}

/* 图片展示 */
.detail-images {
  padding: 0 32rpx 32rpx;
}

.detail-image-single {
  width: 100%;
  border-radius: 12rpx;
}

.detail-images-scroll {
  white-space: nowrap;
}

.detail-image-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  display: inline-block;
  margin-right: 16rpx;
}

/* 底部互动区 */
.interaction-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f2f3f5;
  border-bottom: 1rpx solid #f2f3f5;
  margin-bottom: 32rpx;
}

.interaction-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
}

.interaction-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.interaction-count {
  font-size: 24rpx;
  color: #636e72;
}

.interaction-btn--active .interaction-count {
  color: #534ab7;
}

/* 评论区 */
.comment-section {
  padding: 0 32rpx;
}

.comment-header {
  margin-bottom: 24rpx;
}

.comment-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.comment-list {
  margin-bottom: 32rpx;
}

.comment-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f2f3f5;
}

.comment-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-meta {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.comment-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #1a1a2e;
  margin-right: 8rpx;
}

.comment-badge {
  padding: 2rpx 8rpx;
  background: rgba(83, 74, 183, 0.1);
  color: #534ab7;
  font-size: 18rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
}

.comment-time {
  font-size: 22rpx;
  color: #b2bec3;
}

.comment-text {
  font-size: 28rpx;
  color: #1a1a2e;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.comment-actions {
  display: flex;
  align-items: center;
}

.comment-action {
  font-size: 22rpx;
  color: #636e72;
  margin-right: 24rpx;
}

/* 多轮回复 */
.reply-list {
  margin-top: 16rpx;
  padding-left: 24rpx;
  border-left: 4rpx solid #534ab7;
}

.reply-item {
  display: flex;
  padding: 16rpx 0;
}

.reply-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.reply-body {
  flex: 1;
  min-width: 0;
}

.reply-meta {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
}

.reply-name {
  font-size: 22rpx;
  font-weight: 500;
  color: #1a1a2e;
  margin-right: 8rpx;
}

.reply-badge {
  padding: 2rpx 6rpx;
  background: rgba(83, 74, 183, 0.1);
  color: #534ab7;
  font-size: 16rpx;
  border-radius: 4rpx;
}

.reply-text {
  font-size: 24rpx;
  color: #1a1a2e;
  line-height: 1.6;
}

.reply-expand {
  font-size: 22rpx;
  color: #534ab7;
  padding: 8rpx 0;
  margin-top: 8rpx;
}

/* 空评论 */
.empty-comments {
  text-align: center;
  padding: 48rpx 0;
  font-size: 26rpx;
  color: #b2bec3;
}

/* 底部留白 */
.bottom-spacer {
  height: 200rpx;
}

/* 底部评论输入栏 */
.comment-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-top: 1rpx solid #f2f3f5;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

.reply-tip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 16rpx;
  background: #f8f9fe;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
  font-size: 22rpx;
  color: #534ab7;
}

.reply-cancel {
  font-size: 24rpx;
  color: #b2bec3;
}

.comment-input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #1a1a2e;
}

.comment-send-btn {
  width: 120rpx;
  height: 72rpx;
  background: #534ab7;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 36rpx;
  border: none;
  line-height: 72rpx;
  padding: 0;
}

.comment-send-btn::after {
  border: none;
}

.comment-send-btn[disabled] {
  background: #d1d5db;
  color: #ffffff;
}
