/* pages/detail/detail.wxss */

.page {
  width: 100%;
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 右上角更多按钮 */
.navbar-action {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.navbar-action__icon {
  width: 40rpx;
  height: 40rpx;
}

/* ============================================
   主内容滚动区
   ============================================ */
.content {
  flex: 1;
  height: calc(100vh - 88rpx - env(safe-area-inset-top));
  box-sizing: border-box;
}

/* ============================================
   Hero 区 - .detail-hero
   ============================================ */
.detail-hero {
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 作者信息 */
.detail-author {
  display: flex;
  align-items: center;
  gap: 24rpx;                    /* 12px */
  padding: 32rpx;                /* 16px */
}

.detail-author__avatar {
  width: 80rpx;                  /* 40px */
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #f0f0f0;
}

.detail-author__info {
  flex: 1;
  min-width: 0;
}

.detail-author__name {
  font-size: 30rpx;              /* 15px text-base */
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.3;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.detail-author__me-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 28rpx;
  padding: 0 10rpx;
  border-radius: 4rpx;
  background: #534ab7;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 500;
}

.detail-author__time {
  font-size: 24rpx;              /* 12px text-sm */
  color: #999999;
  margin-top: 4rpx;
}

.detail-author__follow {
  flex-shrink: 0;
  height: 56rpx;                 /* 28px */
  padding: 0 24rpx;
  border-radius: 28rpx;
  background: #eae6ff;           /* primary-light */
  color: #534ab7;
  font-size: 24rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-author__follow--following {
  background: #f0f0f0;
  color: #999999;
}

.detail-author__follow:active {
  opacity: 0.8;
}

/* ============================================
   正文 - .detail-body
   ============================================ */
.detail-body {
  padding: 16rpx 32rpx 32rpx;    /* 8px 16px 16px */
}

.detail-body__title {
  font-size: 40rpx;              /* 20px text-xl */
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.25;
  margin-bottom: 24rpx;          /* 12px */
}

.detail-body__text {
  font-size: 30rpx;              /* 15px text-base */
  line-height: 1.6;
  color: #666666;
  margin-bottom: 32rpx;          /* 16px */
}

.detail-body__tags {
  display: flex;
  gap: 16rpx;                    /* 8px */
  margin-bottom: 32rpx;
  flex-wrap: wrap;
}

/* 图片展示 */
.detail-body__images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.detail-body__image {
  width: 218rpx;                 /* 三列等宽 */
  height: 218rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
}

.detail-body__images .detail-body__image:nth-child(1):nth-last-child(1) {
  /* 单图：放大显示 */
  width: 100%;
  height: 400rpx;
}

.tag-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;                 /* 28px */
  padding: 0 24rpx;
  font-size: 24rpx;
  border-radius: 28rpx;
}

.tag-chip--default {
  background: #f0f0f0;
  color: #666666;
}

.tag-chip--green {
  background: #e6f9ef;
  color: #07c160;
}

/* ============================================
   认领成果 - .detail-results
   ============================================ */
.detail-results {
  padding: 32rpx;
  margin-top: 16rpx;             /* 8px */
  background: #ffffff;
}

.detail-results__title {
  font-size: 30rpx;              /* 15px text-base */
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.detail-results__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.result-thumb {
  aspect-ratio: 1;
  border-radius: 16rpx;          /* radius-md */
  background: #f0eff5;           /* bg-tag */
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}

.result-thumb__img {
  width: 100%;
  height: 100%;
}

.result-thumb__placeholder {
  width: 56rpx;
  height: 56rpx;
  background: #bfbfbf;
  border-radius: 8rpx;
  opacity: 0.3;
}

.result-thumb--video::after {
  content: '';
  position: absolute;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.45);
}

/* ============================================
   CTA - .detail-cta
   ============================================ */
.detail-cta {
  padding: 32rpx;
}

.cta-btn {
  width: 100%;
  height: 88rpx;                 /* 44px */
  border-radius: 24rpx;          /* radius-lg */
  border: none;
  background: #534ab7;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 88rpx;
}

.cta-btn::after {
  border: none;
}

.cta-btn:active {
  background: #42389e;
}

.cta-btn--disabled {
  background: #c0c0c0;
  color: rgba(255, 255, 255, 0.85);
}

.cta-btn--disabled:active {
  background: #c0c0c0;
}

.detail-cta__meta {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  margin-top: 16rpx;
}

/* 加载占位 */
.detail-loading {
  padding: 120rpx 0;
  text-align: center;
}

.detail-loading__text {
  font-size: 28rpx;
  color: #999999;
}

/* ============================================
   评论 - .detail-comments
   ============================================ */
.detail-comments {
  padding: 32rpx;
  background: #ffffff;
  margin-top: 16rpx;
  border-radius: 24rpx 24rpx 0 0;
}

.detail-comments__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 32rpx;
}

.comment-item {
  display: flex;
  gap: 24rpx;
  padding-bottom: 32rpx;
  margin-bottom: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.comment-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.comment-item__avatar {
  width: 64rpx;                  /* 32px */
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #f0f0f0;
}

.comment-item__body {
  flex: 1;
  min-width: 0;
}

.comment-item__name {
  font-size: 28rpx;              /* 14px text-md */
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 4rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.comment-item__author-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 28rpx;
  padding: 0 10rpx;
  border-radius: 4rpx;
  background: #534ab7;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 500;
}

.comment-item__text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.comment-item__meta {
  font-size: 24rpx;
  color: #999999;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.comment-item__action {
  color: #999999;
}

.comment-item__action:active {
  color: #534ab7;
}

.comment-item__like {
  display: flex;
  align-items: center;
  gap: 6rpx;
  color: #999999;
  margin-left: auto;
}

.comment-item__like-icon {
  width: 24rpx;
  height: 24rpx;
}

/* ============================================
   楼中楼回复 - .comment-replies
   ============================================ */
.comment-replies {
  margin-top: 24rpx;
  padding-left: 32rpx;
  border-left: 3rpx solid #eae6ff;  /* 1.5px brand-purple-100 */
}

.comment-reply {
  display: flex;
  gap: 16rpx;
  padding-bottom: 24rpx;
  margin-bottom: 24rpx;
}

.comment-reply:last-child {
  padding-bottom: 0;
  margin-bottom: 0;
}

.comment-reply__avatar {
  width: 48rpx;                  /* 24px */
  height: 48rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #f0f0f0;
}

.comment-reply__body {
  flex: 1;
  min-width: 0;
}

.comment-reply__name {
  font-size: 24rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 4rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.comment-reply__author-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 32rpx;
  padding: 0 12rpx;
  border-radius: 4rpx;
  background: #534ab7;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 500;
}

.comment-reply__reply-to {
  font-weight: 400;
  color: #534ab7;
  font-size: 22rpx;
}

.comment-reply__text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.comment-reply__meta {
  font-size: 22rpx;
  color: #bfbfbf;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.comment-replies__more {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #534ab7;
  font-weight: 500;
  padding-top: 8rpx;
}

.comment-replies__more:active {
  opacity: 0.7;
}

.comment-replies__more-icon {
  width: 28rpx;
  height: 28rpx;
}

/* ============================================
   评论空状态
   ============================================ */
.comments-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.comments-empty__icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.3;
}

.comments-empty__text {
  font-size: 28rpx;
  color: #999999;
}

/* ============================================
   底部留白
   ============================================ */
.bottom-spacer {
  height: 160rpx;                /* 80px */
}

/* ============================================
   底部输入栏 - .comment-bar
   ============================================ */
.comment-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 50;
}

.comment-bar__reply-tip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.comment-bar__reply-cancel {
  color: #bfbfbf;
  font-size: 28rpx;
  padding: 0 8rpx;
}

.comment-bar__row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.comment-bar__input {
  flex: 1;
  height: 72rpx;                 /* 36px */
  background: #f7f8fa;
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #1a1a1a;
}

.comment-bar__publish {
  flex-shrink: 0;
  height: 72rpx;
  padding: 0 32rpx;
  border-radius: 36rpx;
  background: #eae6ff;
  color: #bfbfbf;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s;
}

.comment-bar__publish--active {
  background: #534ab7;
  color: #ffffff;
}

.comment-bar__publish--active:active {
  background: #42389e;
}
