<!-- pages/detail/index.wxml -->
<view class="page">
  <!-- 自定义导航栏 -->
  <navbar
    type="white"
    title="创意详情"
    show-back="{{true}}"
    right-text="···"
    bind:rightClick="onMoreClick"
  ></navbar>

  <block wx:if="{{loading && !detail}}">
    <view class="loading-tip">加载中...</view>
  </block>

  <block wx:elif="{{detail}}">
    <scroll-view scroll-y class="scroll-area" enhanced show-scrollbar="{{false}}">
      <!-- 作者信息 -->
      <view class="author-section">
        <view class="author-info" bindtap="onAuthorClick">
          <image class="author-avatar" src="{{detail.author.avatar}}" mode="aspectFill"></image>
          <view class="author-meta">
            <text class="author-name">{{detail.author.name}}</text>
            <text class="author-time">{{detail.timeLabel}}</text>
          </view>
        </view>
        <view
          class="follow-btn {{detail.author.isFollowing ? 'follow-btn--active' : ''}}"
          bindtap="onFollowClick"
        >
          {{detail.author.isFollowing ? '已关注' : '+ 关注'}}
        </view>
      </view>

      <!-- 推荐理由标签 -->
      <view class="recommend-tag" wx:if="{{detail.recommendReason}}">
        <text>{{detail.recommendReason}}</text>
      </view>

      <!-- 标题 -->
      <view class="detail-title" wx:if="{{detail.title}}">{{detail.title}}</view>

      <!-- 正文内容 -->
      <view class="detail-content">{{detail.content}}</view>

      <!-- 图片展示 -->
      <view class="detail-images" wx:if="{{detail.images.length > 0}}">
        <!-- 单图 -->
        <image
          wx:if="{{detail.images.length === 1}}"
          class="detail-image-single"
          src="{{detail.images[0]}}"
          mode="widthFix"
          bindtap="onPreviewImage"
          data-index="0"
        ></image>

        <!-- 多图横滑 -->
        <scroll-view
          wx:else
          scroll-x
          class="detail-images-scroll"
          enhanced
          show-scrollbar="{{false}}"
        >
          <image
            wx:for="{{detail.images}}"
            wx:key="index"
            class="detail-image-item"
            src="{{item}}"
            mode="aspectFill"
            bindtap="onPreviewImage"
            data-index="{{index}}"
          ></image>
        </scroll-view>
      </view>

      <!-- 底部互动区 -->
      <view class="interaction-bar">
        <view class="interaction-btn {{isLiked ? 'interaction-btn--active' : ''}}" bindtap="onLike">
          <text class="interaction-icon">{{isLiked ? '❤️' : '🤍'}}</text>
          <text class="interaction-count">{{likeCount}}</text>
        </view>
        <view class="interaction-btn" bindtap="onScrollToComment">
          <text class="interaction-icon">💬</text>
          <text class="interaction-count">{{commentCount}}</text>
        </view>
        <view class="interaction-btn" bindtap="onShare">
          <text class="interaction-icon">↗️</text>
        </view>
      </view>

      <!-- 评论区 -->
      <view class="comment-section" id="comment-section">
        <view class="comment-header">
          <text class="comment-title">评论 {{commentCount}}</text>
        </view>

        <view class="comment-list" wx:if="{{comments.length > 0}}">
          <view class="comment-item" wx:for="{{comments}}" wx:key="id">
            <image class="comment-avatar" src="{{item.author.avatar}}" mode="aspectFill"></image>
            <view class="comment-body">
              <view class="comment-meta">
                <text class="comment-name">{{item.author.name}}</text>
                <text class="comment-badge" wx:if="{{item.author.isAuthor}}">作者</text>
                <text class="comment-time">{{item.timeLabel}}</text>
              </view>
              <view class="comment-text">{{item.content}}</view>
              <view class="comment-actions">
                <text class="comment-action" bindtap="onReplyComment" data-id="{{item.id}}" data-name="{{item.author.name}}">回复</text>
              </view>

              <!-- 多轮回复 -->
              <view class="reply-list" wx:if="{{item.replies && item.replies.length > 0}}">
                <view class="reply-item" wx:for="{{item.replies}}" wx:key="id" wx:for-item="reply">
                  <image class="reply-avatar" src="{{reply.author.avatar}}" mode="aspectFill"></image>
                  <view class="reply-body">
                    <view class="reply-meta">
                      <text class="reply-name">{{reply.author.name}}</text>
                      <text class="reply-badge" wx:if="{{reply.author.isAuthor}}">作者</text>
                    </view>
                    <view class="reply-text">{{reply.content}}</view>
                  </view>
                </view>

                <view class="reply-expand" wx:if="{{item.replies.length > 2 && !item.repliesExpanded}}" bindtap="onExpandReplies" data-id="{{item.id}}">
                  展开更多回复 ({{item.replies.length - 2}})
                </view>
              </view>
            </view>
          </view>
        </view>

        <view class="empty-comments" wx:else>
          <text>暂无评论，快来抢沙发</text>
        </view>
      </view>

      <view class="bottom-spacer"></view>
    </scroll-view>

    <!-- 底部评论输入栏 -->
    <view class="comment-bar">
      <view class="reply-tip" wx:if="{{replyTo}}">
        <text>回复 {{replyTo.name}}</text>
        <text class="reply-cancel" bindtap="onCancelReply">✕</text>
      </view>
      <view class="comment-input-wrap">
        <input
          class="comment-input"
          placeholder="{{replyTo ? '回复 ' + replyTo.name : '说点什么吧...'}}"
          value="{{commentText}}"
          bindinput="onCommentInput"
          confirm-type="send"
          bindconfirm="onSendComment"
        />
        <button
          class="comment-send-btn"
          bindtap="onSendComment"
          disabled="{{!commentText}}"
        >发布</button>
      </view>
    </view>
  </block>
</view>
