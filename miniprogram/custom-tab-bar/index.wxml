<!-- custom-tab-bar/index.wxml -->
<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="index"
    class="tab-item {{active === index ? 'tab-item--active' : ''}} {{index === 2 ? 'center-slot' : ''}}"
    bindtap="switchTab"
    data-index="{{index}}"
  >
    <block wx:if="{{index !== 2}}">
      <image class="tab-icon" src="{{active === index ? item.iconActive : item.icon}}"></image>
      <view class="tab-text">{{item.text}}</view>
    </block>
  </view>

  <!-- 中央凸起的发布按钮 -->
  <view class="center-btn" bindtap="switchTab" data-index="2"></view>
</view>
