/* app.wxss - 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'PingFang SC', 'Hiragino Sans GB', sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  color: #1a1a2e;
  background-color: #f8f9fe;
  --color-primary: #6c5ce7;
  --color-primary-light: #a29bfe;
  --color-primary-dark: #5b4dbc;
  --color-accent: #ff6b6b;
  --color-success: #6bcb77;
  --color-warning: #ffd93d;
  --color-error: #ff6b6b;
  --color-info: #4ecdc4;
  --color-bg-page: #f8f9fe;
  --color-bg-card: #ffffff;
  --color-bg-gradient: #f0f0ff;
  --color-text-primary: #1a1a2e;
  --color-text-secondary: #636e72;
  --color-text-tertiary: #b2bec3;
  --color-text-white: #ffffff;
  --color-border: #e5e6eb;
  --color-divider: #f2f3f5;
}

/* 通用样式类 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

.ellipsis-3 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 紫蓝渐变 */
.gradient-primary {
  background: linear-gradient(135deg, #6c5ce7 0%, #a29bfe 100%);
}

.gradient-header {
  background: linear-gradient(180deg, #6c5ce7 0%, #a29bfe 100%);
}

.gradient-accent {
  background: linear-gradient(135deg, #ff6b6b 0%, #ffa8a8 100%);
}

/* 卡片 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 标签胶囊 */
.tag {
  padding: 4rpx 16rpx;
  background: #f0f0ff;
  color: #6c5ce7;
  font-size: 22rpx;
  border-radius: 999rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
  display: inline-block;
}

/* 加载提示 */
.loading-tip {
  text-align: center;
  padding: 32rpx 0;
  font-size: 24rpx;
  color: #b2bec3;
}

/* 占位页底部留白（适配自定义中央凸起 tabBar，高度 160rpx） */
.page-bottom-spacer {
  height: 160rpx;
}
